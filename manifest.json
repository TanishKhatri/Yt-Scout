{
  "manifest_version": 3,
  "name": "YT Keyword Scout",
  "version": "1.0.0",
  "description": "Search YouTube keywords and instantly surface video & channel analytics, tags, and engagement metrics.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.googleapis.com/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "YT Keyword Scout"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}